# Yallai — copy the right file to the right place:
#
#   frontend/.env.example  →  frontend/.env.local   (BACKEND_URL for Next proxy)
#   backend/.env.example   →  backend/.env          (Mongo + EMERGENT_LLM_KEY)
#
# Next.js loads BACKEND_URL from frontend/.env.local (default http://127.0.0.1:8000).

NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_URL=http://127.0.0.1:8000
