# Canonical URL for SEO and share links (production: https://yallai.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Your login credentials (only you have access)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your-secure-password

# Secret used to sign session cookies — change this to a random string
SESSION_SECRET=change-me-to-a-random-32-char-string

# ── AWS Bedrock (default AI provider) ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Other AI providers (optional — configured per-user in Settings UI) ───────
# Anthropic, OpenAI, and DeepSeek API keys are entered in the app's Settings
# modal and stored in the browser (localStorage). They are never stored server-side.
