# Canonical URL for SEO and share links (production: https://yallai.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Your login credentials (only you have access)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your-secure-password

# Secret used to sign session cookies — change this to a random string
SESSION_SECRET=change-me-to-a-random-32-char-string

# ── AWS Bedrock (default AI provider) ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Other AI providers (optional — configured per-user in Settings UI) ───────
# Anthropic, OpenAI, and DeepSeek API keys are entered in the app's Settings
# modal and stored in the browser (localStorage). They are never stored server-side.

# ── Neon Database (PostgreSQL) ───────────────────────────────────────────────
# Neon PostgreSQL connection string (ensure ?sslmode=require is included)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── MongoDB (Legacy - can be removed if using Neon) ──────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=sahib_yalla

# ── Emergent LLM Integration ─────────────────────────────────────────────────
EMERGENT_LLM_KEY=your-emergent-llm-key

# ── Silicon Flow API (OpenAI-compatible for DeepSeek models) ─────────────────
SILICON_FLOW_API_KEY=your-silicon-flow-api-key
SILICON_FLOW_BASE_URL=https://api.siliconflow.cn/v1
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-5-20250929
# Alternative: deepseek-ai/deepseek-coder-33b-instruct or deepseek-ai/deepseek-coder-7b-instruct

# ── Admin Configuration ──────────────────────────────────────────────────────
ADMIN_EMAILS=mortadagzar@gmail.com
