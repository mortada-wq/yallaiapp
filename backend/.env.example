# Required for FastAPI (see server.py)
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=sahib_yalla

# Emergent / unified LLM key (LlmChat)
EMERGENT_LLM_KEY=your-key

# Default model when no admin override and when the client does not send provider+model
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-5-20250929

# Comma-separated emails allowed to use /api/admin/* (HTTP Basic style gate)
ADMIN_EMAILS=you@example.com

# Local http://localhost:3000 — set both so session cookies work without HTTPS
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
